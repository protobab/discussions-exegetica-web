{
  "name": "discussions-exegetica",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "cf:dev": "wrangler pages dev dist --compatibility-date=2024-01-01",
    "cf:deploy": "wrangler pages deploy dist --project-name=discussions-exegetica",
    "db:init": "wrangler d1 execute discussions-exegetica-db --file=./migrations/001_initial.sql",
    "db:migrate": "wrangler d1 execute discussions-exegetica-db --file=./migrations/002_seed.sql"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.1",
    "vite": "^5.4.0",
    "wrangler": "^3.70.0"
  }
}
